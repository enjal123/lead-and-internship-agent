# Copy this file to .env and fill in your own values.
# .env is gitignored and should NEVER be committed.

# --- Email / SMTP (used for sending outreach) ---
# For Gmail: enable 2-Step Verification, then create a 16-character
# "App Password" at https://myaccount.google.com/apppasswords -- do NOT
# use your normal Google account password here.
EMAIL_ADDRESS=you@example.com
EMAIL_PASSWORD=your-app-password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=465

# Name used to sign generated follow-up emails
YOUR_NAME=Your Name

# --- LLM (local, free via Ollama: https://ollama.com) ---
# Install Ollama, then run: ollama pull llama3
OLLAMA_MODEL=llama3

# --- Database ---
DATABASE_PATH=agent.db

# --- Scraping ---
HEADLESS_BROWSER=true
REQUEST_TIMEOUT=10
REQUEST_DELAY_SECONDS=2

# --- Optional paid API (leave blank to use the free search path instead) ---
GOOGLE_PLACES_API_KEY=

# --- Default search queries (optional overrides) ---
INTERNSHIP_SEARCH_QUERY=software engineering internship 2026 apply
BUSINESS_SEARCH_QUERY=small business website Sonoma County California

# --- Prompt personalization (optional) ---
# Multi-line values: use \n or just edit ai/prompts.py defaults in utils/config.py directly.
# CANDIDATE_BACKGROUND=- your background here
# SENDER_BACKGROUND=- your background here
